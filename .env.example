# Copy to .env.local and fill in.  Locally you can run with ZERO cloud accounts:
# just a local Postgres + STORAGE_DRIVER=disk + the keyless Pollinations provider.

# ── Database ─────────────────────────────────────────────────────────────
# Local Postgres (you have psql 18 installed) or a free Neon connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/manga_forge

# ── AI image provider ────────────────────────────────────────────────────
IMAGE_PROVIDER=pollinations                 # pollinations | cloudflare
POLLINATIONS_BASE_URL=https://image.pollinations.ai
# POLLINATIONS_TOKEN=                        # optional; anonymous tier works without a key
# For the "broken response" failure demo you can temporarily point the base URL
# at something that returns non-image HTML (see plan.md §6).

# Cloudflare Workers AI (fallback provider) — only needed if IMAGE_PROVIDER=cloudflare
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# ── Image storage ────────────────────────────────────────────────────────
# Leave STORAGE_DRIVER unset to auto-detect: object storage is used when a full
# S3/R2 credential set is present, otherwise local disk.
# STORAGE_DRIVER=disk                        # force one of: disk | r2 | s3
STORAGE_DISK_DIR=./.data/images             # used for local disk storage

# S3-compatible object storage (Cloudflare R2, etc.) for production. Provide
# EITHER these R2_-prefixed names OR the plain names many providers inject
# (ENDPOINT / BUCKET / REGION / ACCESS_KEY_ID / SECRET_ACCESS_KEY).
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_BUCKET=manga-forge
# R2_REGION=auto
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# ── App ──────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string   # signs the session cookie (HMAC)
GENERATION_TIMEOUT_MS=35000                 # abort an AI call after this many ms → 'timeout' failure
MAX_CONCURRENT_GENERATIONS=4                # p-limit semaphore: simultaneous AI calls in-process
